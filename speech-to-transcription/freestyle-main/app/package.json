{
  "name": "freestyle",
  "version": "0.0.1",
  "description": "Open-source AI voice dictation — local-first, BYOK cloud.",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "install-electron && node scripts/fix-keylistener.mjs && node scripts/build-whisper.mjs",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:icon": "cp assets/app-icon-230-rounded.png build/icon.png",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.freestyle.app",
    "productName": "Freestyle",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "icon": "build/icon.png"
    },
    "linux": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@types/ws": "^8.18.1",
    "electron-updater": "^6.3.9",
    "hono": "^4.6.14",
    "node-global-key-listener": "^0.3.0",
    "nodejs-whisper": "^0.2.9",
    "openai": "^4.77.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.3.3"
  }
}
